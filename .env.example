FTP_HOST=your-ftp-host.com
FTP_USER=
FTP_PASS=
FTP_DIR=/path/to/web/root

BREWERY_NAME=My Brewery
SITE_URL=https://your-site.com
LOGO_PNG=my-brewery-logo.png
LOGO_SVG=my-brewery-logo.svg

# InfluxDB connection (optional — only needed for fetch_influxdb.py)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=
INFLUXDB_BUCKET=brewery

# InfluxDB kettle schema (defaults shown — omit lines you don't need to change)
INFLUXDB_KETTLE_MEASUREMENT=mqtt_consumer
INFLUXDB_KETTLE_TOPIC_TAG=topic
INFLUXDB_KETTLE_TOPICS=home/brewery/temperature/0,home/brewery/temperature/1
INFLUXDB_KETTLE_FIELD=temperature
INFLUXDB_KETTLE_SENSOR_LABELS=0=Kettle,1=Ambient

# InfluxDB iSpindel schema (defaults shown — omit lines you don't need to change)
INFLUXDB_ISPINDEL_MEASUREMENT=ispindel
INFLUXDB_ISPINDEL_SOURCE_TAG=source
INFLUXDB_ISPINDEL_TYPE_TAG=field
INFLUXDB_ISPINDEL_VALUE_FIELD=value
INFLUXDB_ISPINDEL_TEMP_VALUE=temperature
INFLUXDB_ISPINDEL_GRAVITY_VALUE=gravity
